{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuizForge Creator",
  "version": "1.0.0",
  "identifier": "com.quizforge.creator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QuizForge Creator",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: blob: data:; font-src 'self' https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self' https://github.com https://api.github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "startMenuFolder": "QuizForge"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/player-template.exe"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:quizforge.db"
      ]
    },
    "updater": {
      "pubkey": "REPLACE_WITH_YOUR_ED25519_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/YOUR_USERNAME/QuizForge/releases/latest/download/creator-update.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
